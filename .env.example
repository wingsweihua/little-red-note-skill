# ============================================================
# colleague-skill  --  environment variables
# Copy to .env and fill in your own values. NEVER commit .env.
# ============================================================

# ---------- Xiaohongshu (Spider_XHS) ----------
# Open xiaohongshu.com in your browser, sign in, then copy the
# full Cookie header from DevTools → Network → any request.
COOKIES=

# ---------- Feishu / Lark ----------
# https://open.feishu.cn/app  →  your app  →  Credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional: a tenant access token if you prefer to inject one directly
FEISHU_TENANT_ACCESS_TOKEN=

# ---------- DingTalk ----------
# https://open-dev.dingtalk.com  →  your app  →  Basic info
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# ---------- Slack ----------
# Bot token (xoxb-...) from your Slack app's OAuth & Permissions page
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=

# ---------- Email (IMAP) ----------
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=
EMAIL_PASSWORD=

# ---------- Output paths (optional overrides) ----------
# Where generated skills are written. Default: ./colleagues
COLLEAGUE_OUTPUT_DIR=

# ---------- Anthropic (only if you call the API directly) ----------
ANTHROPIC_API_KEY=
